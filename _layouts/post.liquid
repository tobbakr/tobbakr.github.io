---
layout: default
image: assets/img/social_schrijnwerkerijtobback.png
---

{% if page.date_created %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "{{ page.title | escape }}",
      "description": "{{ page.description | escape }}",
      "datePublished": "{{ page.date_created }}",
      "author": {
        "@type": "Person",
        "name": "Kris Tobback",
        "url": "https://schrijnwerkerijtobback.be"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Schrijnwerkerij Tobback",
        "url": "https://schrijnwerkerijtobback.be",
        "logo": {
          "@type": "ImageObject",
          "url": "https://schrijnwerkerijtobback.be/assets/img/icon.svg"
        }
      }
    }
  </script>
{% endif %}

{% assign artikels_sorted = site.artikels | where_exp: 'item', 'item.url != page.url' | sort: 'date_created' | reverse %}
{% assign limited = include.limit_items | default: 3 %}

<section id="sc-hero" class="section-hero div-hero {{ page.hero | default: 'hero-1' }}">
  <div class="container mt-2">
    <div class="row">
      <div class="col-sm-12">
        <div class="div-hero div-hero-text">
          <div>
            <h1 class="hero">{{ page.header }}</h1>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% include breadcrumbs.liquid %}

<div class="container mt-3">
  <div class="row">
    <div class="col-md-7">
      <div class="artikel-meta-bar">
        {% assign words = content | number_of_words %}
        {% assign reading_time = words | divided_by: 200 %}
        {% if reading_time == 0 %}{% assign reading_time = 1 %}{% endif %}
        <span><i class="fa-regular fa-clock"></i> {{ reading_time }} min leestijd</span>
        <span><i class="fa-solid fa-user"></i> Kris Tobback</span>
      </div>
    </div>
  </div>
</div>

<article id="sc-artikel">
  <div class="container mt-3">
    <div class="row">
      <div class="col-md-7 mt-2">
        {{ content }}
      </div>
      <div class="col-md-1 mt-2"></div>
      <div class="col-md-4 mt-2">
        <a href="{{ '/artikels/' | relative_url }}" class="btn btn-outline-secondary btn-sm mb-4">
          <i class="fa-solid fa-arrow-left"></i> Alle artikels
        </a>
        <h3>Meer lezen</h3>
        {% for artikel in artikels_sorted limit: limited %}
          <div class="sidebar-artikel mb-3">
            <a href="{{ artikel.url | relative_url }}">{{ artikel.header }}</a>
            <p class="sidebar-artikel-desc">{{ artikel.description }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</article>

<section id="section-related-werk" class="fade-in-up">
  <div class="container mt-5">
    <div class="row">
      <div class="col-md-12">
        <h2>Recente realisaties</h2>
      </div>
    </div>
    <div class="row">
      {% assign werk_items = site.werk | sort: 'date' | reverse %}
      {% for werk in werk_items limit: 3 %}
        <div class="col-md-4 mb-3">
          {% include werk-card.liquid werk=werk %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% include cta-banner.liquid %}
