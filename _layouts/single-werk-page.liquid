---
layout: single-page
image: assets/img/social_schrijnwerkerijtobback.png
---

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": "{{ page.header | escape }}",
    "description": "{{ page.description | escape }}",
    "image": "{{ site.url }}/{{ page.img }}",
    "dateCreated": "{{ page.date }}",
    "creator": {
      "@type": "Organization",
      "name": "Schrijnwerkerij Tobback",
      "url": "https://schrijnwerkerijtobback.be"
    },
    "locationCreated": {
      "@type": "Place",
      "name": "{{ page.location }}"
    }
  }
</script>

{% include breadcrumbs.liquid %}

<section class="werk-detail">
  <div class="container mt-4">
    <div class="row align-items-start">
      <div class="col-md-5 mb-4">
        <div class="werk-detail-img">
          {% include figure.liquid path=page.img sizes="(min-width: 768px) 450px, 100vw" alt=page.title %}
        </div>
      </div>
      <div class="col-md-7">
        <h2 class="werk-detail-title">{{ page.header }}</h2>
        {% if page.subheader %}
          <p class="werk-detail-sub">{{ page.subheader }}</p>
        {% endif %}
        <div class="werk-detail-meta">
          <span><i class="fa-solid fa-location-dot"></i> {{ page.location }}</span>
          {% for cat in page.categories %}
            <span><i class="fa-solid fa-tag"></i> {{ cat }}</span>
          {% endfor %}
        </div>
        <div class="werk-detail-intro">
          <p>{{ page.description }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% if content != "" %}
<section class="werk-detail-story">
  <div class="container">
    <div class="row">
      <div class="col-lg-8">
        <div class="werk-detail-content">
          {{ content }}
        </div>
        <a href="{{ '/contact/' | relative_url }}" class="btn btn-primary btn-green mt-3 mb-5">
          <i class="fa-solid fa-envelope"></i> Vraag een offerte aan
        </a>
      </div>
    </div>
  </div>
</section>
{% endif %}

{% include cta-banner.liquid %}

<section id="section-related-artikels" class="fade-in-up">
  <div class="container mt-5">
    <div class="row">
      <div class="col-md-12">
        <h2>Tips &amp; advies</h2>
      </div>
    </div>
    <div class="row">
      {% assign artikels = site.artikels | sort: 'date_created' | reverse %}
      {% for artikel in artikels limit: 3 %}
        <div class="col-md-4 mb-3">
          <h3>
            <a href="{{ artikel.url | relative_url }}">{{ artikel.header }}</a>
          </h3>
          <p>{{ artikel.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% include latest_werk.liquid limit_items="4" %}
