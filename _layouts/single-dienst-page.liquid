---
layout: single-page
image: assets/img/social_schrijnwerkerijtobback.png
---
{% include breadcrumbs.liquid %}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "{{ page.title }}",
    "description": "{{ page.description }}",
    "provider": {
      "@type": "HomeAndConstructionBusiness",
      "name": "Schrijnwerkerij Tobback",
      "url": "https://schrijnwerkerijtobback.be"
    },
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": "Vlaams-Brabant"
    },
    "serviceType": "{{ page.category }}"
  }
</script>

{{ content }}

{% assign diensten_sorted = site.diensten | where_exp: 'item', 'item.url != page.url' | sort: 'importance' %}

<section>
  <div class="container mt-5">
    <div class="row">
      <div class="col-sm-12 col-md-8">
        <h2>{{ page.header }}</h2>
        <p>{{ page.description_long }}</p>
      </div>
      <div class="col-sm-12 col-md-4 list-diensten ">
        <h3>Andere diensten</h3>
        <ul class="list-unstyled">
          {% for dienst in diensten_sorted %}
            <li>
              <a href="{{dienst.url}}">{{ dienst.header }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{% include latest_werk.liquid limit_items="4" %}

{% include cta-banner.liquid %}
