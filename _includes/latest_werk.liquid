{% assign werk_sorted = site.werk | where_exp: 'item', 'item.url != page.url' | sort: 'date' | reverse %}
{% assign limited = include.limit_items | default: 4 %}
{% assign category = page.category | join: '' %}
{% assign title = include.title | join: 'Fier op ons werk.' %}

<section id="section-latest" class="fade-in-up">
  <div class="container mt-5 mb-5">
    <div class="row">
      <div class="col-md-12">
        <h2>Fier op ons werk.</h2>
      </div>
    </div>
    <div class="row">
      {% for werk in werk_sorted limit: limited %}
        {% if category == '' or werk.categories contains category %}
          <div class="col-xs-12 col-md-6 col-lg-3 mt-5">
            {% include werk-card.liquid werk=werk %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="row mt-4">
      <div class="col-md-12 text-right">
        <a href="{{ '/werk/' | relative_url }}" class="btn btn-primary btn-green btn-sm">Ontdek meer realisaties</a>
      </div>
    </div>
  </div>
</section>
