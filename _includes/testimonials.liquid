<section id="section-testimonials" class="testimonials-section fade-in-up">
  <div class="container pt-5 pb-5">
    <div class="row">
      <div class="col-md-12">
        <h2>Wat onze klanten zeggen</h2>
      </div>
    </div>
    <div class="row mt-3">
      {% for testimonial in site.data.testimonials %}
        <div class="col-sm-12 col-md-6 col-lg-3 mb-4">
          <div class="card h-100 border-0 shadow-sm testimonial-card">
            <div class="card-body p-4">
              <div class="testimonial-stars mb-2">
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
              </div>
              <p class="testimonial-quote">"{{ testimonial.quote }}"</p>
              <div class="testimonial-author">
                <strong>{{ testimonial.name }}</strong>
                <div class="text-muted"><i class="fa-solid fa-location-dot"></i> {{ testimonial.location }} &mdash; {{ testimonial.project }}</div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
